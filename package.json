    "colors": [
      {
        "id": "pasteShield.criticalForeground",
        "description": "Foreground color for critical severity detections",
        "defaults": {
          "dark": "editorError.foreground",
          "light": "editorError.foreground",
          "highContrast": "errorForeground"
        }
      },
      {
        "id": "pasteShield.highForeground",
        "description": "Foreground color for high severity detections",
        "defaults": {
          "dark": "editorWarning.foreground",
          "light": "editorWarning.foreground",
          "highContrast": "errorForeground"
        }
      },
      {
        "id": "pasteShield.mediumForeground",
        "description": "Foreground color for medium severity detections",
        "defaults": {
          "dark": "editorInfo.foreground",
          "light": "editorInfo.foreground",
          "highContrast": "foreground"
        }
      },
      {
        "id": "pasteShield.lowForeground",
        "description": "Foreground color for low severity detections",
        "defaults": {
          "dark": "descriptionForeground",
          "light": "descriptionForeground",
          "highContrast": "foreground"
        }
      }
    ]
