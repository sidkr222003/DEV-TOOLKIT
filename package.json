{
  "name": "dev-toolkit",
  "displayName": "Dev Toolkit",
  "description": "Developer utilities: file size display, console log removal, AI-enhanced code explanation, and reference tracking",
  "version": "1.1.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "Education",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:devToolkit.showFileSize",
    "onCommand:devToolkit.removeConsoleLogs",
    "onCommand:devToolkit.explainSelectedCode",
    "onCommand:devToolkit.showFunctionReferences",
    "onCommand:devToolkit.refreshReferences",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onView:devToolkit.codeExplainer"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0"
  },
  "contributes": {
    "configuration": {
      "title": "Dev Toolkit",
      "properties": {
        "devToolkit.enableCopilotFallback": {
          "type": "boolean",
          "default": true,
          "description": "Use GitHub Copilot (mini model) to enhance code explanations with AI. 0x cost for extensions. Disable to use static analysis only."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devToolkit",
          "title": "Dev Toolkit",
          "icon": "resources/dev-toolkit.svg"
        }
      ]
    },
    "views": {
      "devToolkit": [
        {
          "id": "devToolkit.codeExplainer",
          "type": "webview",
          "name": "Code Explainer"
        }
      ]
    },
    "commands": [
      {
        "command": "devToolkit.showFileSize",
        "title": "Dev Toolkit: Show File Size",
        "icon": "$(file)"
      },
      {
        "command": "devToolkit.removeConsoleLogs",
        "title": "Dev Toolkit: Remove Console Logs",
        "icon": "$(trash)"
      },
      {
        "command": "devToolkit.explainSelectedCode",
        "title": "Dev Toolkit: Explain Selected Code",
        "icon": "$(book)"
      },
      {
        "command": "devToolkit.showFunctionReferences",
        "title": "Dev Toolkit: Show Function References",
        "icon": "$(references)",
        "category": "Dev Toolkit"
      },
      {
        "command": "devToolkit.refreshReferences",
        "title": "Dev Toolkit: Refresh Reference Data",
        "icon": "$(refresh)",
        "category": "Dev Toolkit"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "devToolkit.showFunctionReferences",
          "when": "false"
        },
        {
          "command": "devToolkit.refreshReferences",
          "when": "editorLangId in ['javascript','typescript','javascriptreact','typescriptreact']"
        }
      ],
      "explorer/context": [
        {
          "command": "devToolkit.showFileSize",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "devToolkit.removeConsoleLogs",
          "when": "!explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "devToolkit.showFileSize",
          "when": "editorTextFocus"
        },
        {
          "command": "devToolkit.removeConsoleLogs",
          "when": "editorTextFocus && !editorReadonly"
        },
        {
          "command": "devToolkit.explainSelectedCode",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "devToolkit.showFunctionReferences",
          "when": "editorTextFocus && editorLangId in ['javascript','typescript','javascriptreact','typescriptreact']",
          "group": "references"
        }
      ],
      "editor/title": [
        {
          "command": "devToolkit.refreshReferences",
          "when": "editorLangId in ['javascript','typescript','javascriptreact','typescriptreact']",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devToolkit.explainSelectedCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "devToolkit.showFunctionReferences",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && editorLangId in ['javascript','typescript','javascriptreact','typescriptreact']"
      }
    ]
  }
}